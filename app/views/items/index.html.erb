<h1>All the items</h1>
<% @items.each do |item|  %>
<p><%= item.name %></p>
<%= link_to item_path(item) do %>
      <%= cl_image_tag item.photo.key, width: 300, crop: :fill, class: "rounded shadow" %>
    <% end %>
    <div>
      <%= link_to "Edit", edit_item_path(item), class: "btn btn-sm btn-outline-secondary mt-2" %>
    </div>
<% end %>
