<div class="container d-flex flex-column align-items-center text-center">
  <div class="container d-flex flex-column align-items-center mt-3">
    <div class="container body-container pt-3">
    <div class="container d-flex justify-content-center mt-1">
      <p><strong>My Closet</strong></p>
    </div>
  <div class="container my-1" data-controller="filter-items">
    <%= link_to "Add to your Closet", new_item_path, class: "main-button mb-4" %>
    <p>FIlter by Category</p>
    <div class="container mb-3">
      <select class="form-select" data-action="change->filter-items#filter" data-filter-items-target="select">
        <option value="">All</option>
        <option value="top">Top</option>
        <option value="bottom">Bottom</option>
        <option value="footwear">Footwear</option>
        <option value="outer">Outer</option>
      </select>
    </div>
    <ul class="nav nav-tabs mb-2 items-status-tabs" id="items-status-tabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="owned-tab" data-bs-toggle="tab" data-bs-target="#owned" type="button" role="tab" aria-controls="owned" aria-selected="true">
          <span>My closet</span>
          <span class="items-tab-count"><%= @owned_items.size %></span>
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="not-bought-tab" data-bs-toggle="tab" data-bs-target="#not-bought" type="button" role="tab" aria-controls="not-bought" aria-selected="false">
          <span>Wishlist</span>
          <span class="items-tab-count"><%= @not_bought_items.size %></span>
        </button>
      </li>
    </ul>
    <p class="items-tab-hint">Tap a tab to switch lists.</p>

    <div class="tab-content" id="items-status-content">
      <div class="tab-pane fade show active" id="owned" role="tabpanel" aria-labelledby="owned-tab">
        <div class="cards-wrapper">
          <% @owned_items.each do |item| %>
            <div class="product-card" data-filter-items-target="card" data-slot="<%= item.slot.downcase %>">
              <div class="product-image product-image-wrapper" style="object-fit: cover;">
                <%= link_to item_path(item) do %>
                  <%= cl_image_tag item.photo.key if item.photo.attached? %>
                  <span class="product-badge rounded-pill bg-primary"><%= item.slot %></span>
                <% end %>
              </div>
              <p class="product-title"><%= item.name %></p>
              <p class="product-subtitle"><%= truncate(item.description, length: 60) %></p>
            </div>
          <% end %>
        </div>
      </div>

      <div class="tab-pane fade" id="not-bought" role="tabpanel" aria-labelledby="not-bought-tab">
        <div class="cards-wrapper">
          <% @not_bought_items.each do |item| %>
            <div class="product-card" data-filter-items-target="card" data-slot="<%= item.slot.downcase %>">
              <div class="product-image product-image-wrapper" style="object-fit: cover;">
                <%= link_to item_path(item) do %>
                  <%= cl_image_tag item.photo.key if item.photo.attached? %>
                  <span class="product-badge rounded-pill bg-primary"><%= item.slot %></span>
                <% end %>
              </div>
              <p class="product-title"><%= item.name %></p>
              <p class="product-subtitle"><%= truncate(item.description, length: 60) %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
 </div>

  </div>
</div>
