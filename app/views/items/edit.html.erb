<%= form_with(model: @item, local: true) do |f| %>
  <div class="form-inputs">
    <div class="mb-3">
      <label class="btn btn-outline-secondary w-100 rounded-pill">
        📷 Change Photo
        <%= f.file_field :photo, accept: 'image/*', capture: 'camera', class: "d-none" %>
      </label>
    </div>

    <div class="mb-3">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control rounded-pill" %>
    </div>

    <div class="mb-3">
      <%= f.label :description, class: "form-label" %>
      <%= f.text_area :description, rows: 3, class: "form-control rounded-3" %>
    </div>

    <div class="row">
      <div class="col-6">
        <%= f.label :category, class: "form-label" %>
        <%= f.select :category, ["Tops", "Bottoms", "Shoes"], {}, { class: "form-select rounded-pill" } %>
      </div>
      <div class="col-6">
        <%= f.label :slot, class: "form-label" %>
        <%= f.select :slot, ["Casual", "Business"], {}, { class: "form-select rounded-pill" } %>
      </div>
    </div>
  </div>

  <div class="form-actions mt-4 d-grid gap-2">
    <%= f.submit "Update Item", class: "btn btn-primary btn-lg rounded-pill" %>
  </div>
<% end %>
