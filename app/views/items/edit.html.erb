<div class="container py-4">
  <div class="col-12 col-md-6 mx-auto text-center">

    <h1 class="mb-4">Edit Item</h1>

    <%= form_with(model: @item, local: true) do |f| %>
      <div class="form-inputs text-start">

        <div class="mb-4 text-center">
          <label class="btn btn-outline-secondary w-100 rounded-pill py-2">
            📷 Change Photo
            <%= f.file_field :photo, accept: 'image/*', capture: 'camera', class: "d-none" %>
          </label>
        </div>

        <div class="mb-3">
          <%= f.label :name, class: "form-label fw-bold" %>
          <%= f.text_field :name, class: "form-control rounded-pill" %>
        </div>

        <div class="mb-3">
          <%= f.label :description, class: "form-label fw-bold" %>
          <%= f.text_area :description, rows: 3, class: "form-control rounded-3" %>
        </div>

        <div class="row g-2">
          <div class="col-6">
            <%= f.label :category, class: "form-label fw-bold" %>
            <%= f.select :category, ["sports", "casual", "formal", "outdoor"], {}, { class: "form-select rounded-pill" } %>
          </div>
          <div class="col-6">
            <%= f.label :slot, class: "form-label fw-bold" %>
            <%= f.select :slot, ["outerwear", "top", "bottom", "footwear"], {}, { class: "form-select rounded-pill" } %>
          </div>
        </div>
      </div>

      <div class="form-actions mt-5">
        <%= f.submit "Update Item", class: "btn btn-primary btn-lg rounded-pill w-100 shadow" %>


        <div class="mt-3">
          <%= link_to "Cancel", item_path(@item), class: "text-muted text-decoration-none" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
