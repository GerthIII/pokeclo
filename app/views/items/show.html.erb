<div class="container py-3 pb-5 item-show-page">
  <article class="item-show-card">
    <div class="item-show-media">
      <% if @item.photo.attached? %>
        <%= cl_image_tag @item.photo.key, class: "item-show-image" %>
      <% else %>
        <div class="item-show-image-placeholder">No image</div>
      <% end %>
    </div>

     <div class="d-flex align-items-center ">
          <p class="item-show-title"><%= @item.name.capitalize %></p>
          <%= link_to edit_item_path(@item) do %>
            <%= image_tag "pencil-icon2.png", alt: "Edit", style: "width: 20px; height: 20px; margin-left: 5px;" %>
          <% end %>


      <% if @item.description.present? %>
        <p class="item-show-description" hidden><%= @item.description %></p>
      <% end %>

    </div>
      <div class="item-show-meta mt-3">
        <span class="item-show-pill"><%= @item.category %></span>
        <span class="item-show-pill"><%= @item.slot %></span>
      </div>
      <div class="item-show-actions">
        <%= link_to "Make an outfit", new_outfit_path(item_id: @item.id), class: "main-button" %>
        <% if @item.status == 2 %>
          <%= button_to "I bought this item",
                        mark_as_bought_item_path(@item),
                        method: :patch,
                        class: "main-button",
                        form: { data: { turbo_confirm: "Mark this item as bought?" } } %>
        <% end %>
      </div>
  </article>
</div>
