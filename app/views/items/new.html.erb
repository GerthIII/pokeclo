<h1>Take a photo to upload your item</h1>

<%= simple_form_for(@item) do |f| %>
  <%= f.error_notification %>

  <div class="form-inputs">
    <%# カメラ起動ボタン %>
    <div class="mb-4 text-center">
      <label class="btn btn-secondary btn-lg w-100">
        📷 Take a Photo
        <%= f.input_field :photo,
                          as: :file,
                          accept: 'image/*',
                          capture: 'camera',
                          class: "d-none" %>
      </label>
      <small class="text-muted">Tap to open your camera</small>
    </div>

    <%= f.input :name, label: "Name", placeholder: "e.g., Vintage Levi's Jacket" %>
    <%= f.input :description, label: "Description", placeholder: "Details about fit, material..." %>

    <%# 選択式にするとスマホで入力しやすくなります %>
    <%= f.input :category, collection: ["Jacket", "Tops", "Bottoms", "Shoes"], prompt: "Select category" %>
    <%= f.input :slot, collection: ["Casual", "Business", "Sports", "Party"], prompt: "Select slot" %>
  </div>

  <div class="form-actions mt-4">
    <%= f.button :submit, "Add to Closet", class: "btn-primary btn-lg w-100" %>
  </div>
<% end %>
