<div class="item-form" data-controller="photo-analyze">
  <p class="item-form__title">What are you trying today?</p>
  <%= simple_form_for @item, html: { class: "item-form__card" } do |f| %>
    <div class="item-form__preview d-none" data-photo-analyze-target="preview">
      <img src="" alt="Uploaded item preview" data-photo-analyze-target="previewImage">
    </div>
    <div class="form-inputs">
      <div data-photo-analyze-target="spinner" class="text-center my-4 <%= params[:from_camera] ? '' : 'd-none' %>">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-2">Analyzing your item...</p>
      </div>
      <div data-photo-analyze-target="fields" class="<%= 'd-none' if params[:from_camera] %>">
        <div class="item-form__field mb-3">
          <%= f.input :name, label: "Name",
                        placeholder: "e.g., Vintage Levi's Jacket",
                        input_html: { class: "item-input", data: { photo_analyze_target: "name" } } %>
        </div>
        <div class="item-form__field mb-3">
          <%= f.input :description, label: "Description",
                        placeholder: "Details about fit, material...",
                        input_html: { class: "item-input", data: { photo_analyze_target: "description" } } %>
        </div>
        <div class="item-form__field mb-3">
          <%= f.input :category, collection: Item::CATEGORY,
                        prompt: "Select category",
                        input_html: { class: "item-input", data: { photo_analyze_target: "category" } } %>
        </div>
        <div class="item-form__field mb-3">
          <%= f.input :slot, collection: Item::SLOT,
                        prompt: "Select slot",
                        input_html: { class: "item-input", data: { photo_analyze_target: "slot" } } %>
        </div>
      </div>
    </div>
    <div class="form-actions mt-4 <%= 'd-none' if params[:from_camera] %>" data-photo-analyze-target="submitButton">
      <%= f.button :submit, "Go to the Fitting Room", class: "container d-flex justify-content-center main-button main-button--cta mb-3" %>
      <label class="retake-btn d-block text-center text-muted small">
        <i class="fa-solid fa-rotate-left me-1"></i> Retake photo
        <%= f.input_field :photo,
                          as: :file,
                          accept: 'image/*',
                          capture: 'camera',
                          class: "d-none",
                          data: { photo_analyze_target: "photo", action: "change->photo-analyze#photoChanged" } %>
      </label>
    </div>
  <% end %>
</div>
