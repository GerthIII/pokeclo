<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pokeclo" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pokeclo">
    <meta name="mobile-web-app-capable" content="yes">

    <%# Rails 8 標準のパス指定（ここが重要です） %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path %>

    <%# アイコンも logo.png を使うように合わせます %>
    <link rel="apple-touch-icon" href="<%= asset_path 'apple-touch-icon' %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
  <% unless current_page?(root_path) || devise_controller? %>
  <% end %>
  <%= render "shared/flashes" %>
    <%= yield %>
    <%= render "shared/navbar", class: "footer" %>
  </body>
</html>
