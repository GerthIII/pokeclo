<h1>Create New Outfit</h1>

<%= form_with model: @outfit do |f| %>

  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <%= f.submit "Create Outfit" %>

<% end %>

<%= link_to "Back", outfits_path %>
