<div class="outfit-edit">
  <h1>New Outfit</h1>

  <%= simple_form_for @outfit, html: { multipart: true } do |f| %>

    <div class="edit-container">

      <div class="left-column">
        <%= f.input :name %>
        <%= f.input :description %>
        <%= f.input :status %>
        <%= f.input :jacket, as: :file %>

        <%= f.submit "Create Item", class:"btn btn-primary" %>
      </div>

      <div class="action-column">
        <%= f.submit "CREATE", class: "btn" %>
        <%= link_to "ADVICE", "#", class: "btn" %>
        <%= link_to "OMAKASE", "#", class: "btn bottom-btn" %>
      </div>

    </div>

  <% end %>
</div>
