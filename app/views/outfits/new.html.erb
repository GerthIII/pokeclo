<div class="item-form">
  <h1 class="item-form__title">New Outfit</h1>

  <%= simple_form_for @outfit, html: { multipart: true, class: "item-form__card" } do |f| %>

    <div class="form-inputs">

      <!-- 左カラム -->
      <div class="form-fields">
        <div class="item-form__field mb-3">
          <%= f.input :name, input_html: { class: "item-input" } %>
        </div>

        <div class="item-form__field mb-3">
          <%= f.input :description, input_html: { class: "item-input" } %>
        </div>

        <div class="slot-grid">

          <button
            class="slot-square"
            data-slot="top"
            type="button"
            data-bs-toggle="offcanvas"
            data-bs-target="#top-sheet">
            Top
          </button>

          <button
            class="slot-square"
            data-slot="bottom"
            type="button"
            data-bs-toggle="offcanvas"
            data-bs-target="#bottom-sheet">
            Bottom
          </button>

          <button
            class="slot-square"
            data-slot="footwear"
            type="button"
            data-bs-toggle="offcanvas"
            data-bs-target="#footwear-sheet">
            Shoes
          </button>

          <button
            class="slot-square"
            data-slot="outer"
            type="button"
            data-bs-toggle="offcanvas"
            data-bs-target="#outer-sheet">
            Outer
          </button>

        </div>


        <!-- TOP -->
        <div class="offcanvas offcanvas-bottom slot-sheet" tabindex="-1" id="top-sheet">
          <div class="offcanvas-header">
            <h5 class="offcanvas-title">Select a Top</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
          </div>

          <div class="offcanvas-body">
            <div class="items-scroll-row">

              <% @tops.each do |item| %>
                <div class="item-choice-wrapper">

                  <%= radio_button_tag "outfit[top_item_id]",
                      item.id,
                      @outfit.top_item_id.to_i == item.id,
                      id: "top_item_#{item.id}",
                      class: "item-radio",
                      data: { slot: "top", image: cl_image_path(item.photo.key) } %>

                  <label for="top_item_<%= item.id %>" class="item-card-choice">
                    <% if item.photo.attached? %>
                      <%= cl_image_tag item.photo.key, class: "item-card-image" %>
                    <% end %>

                    <p class="item-card-name"><%= item.name %></p>
                  </label>

                </div>
              <% end %>

            </div>
          </div>
        </div>


        <!-- BOTTOM -->
        <div class="offcanvas offcanvas-bottom slot-sheet" tabindex="-1" id="bottom-sheet">
          <div class="offcanvas-header">
            <h5 class="offcanvas-title">Select Bottom</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
          </div>

          <div class="offcanvas-body">
            <div class="items-scroll-row">

              <% @bottoms.each do |item| %>
                <div class="item-choice-wrapper">

                  <%= radio_button_tag "outfit[bottom_item_id]",
                      item.id,
                      @outfit.bottom_item_id.to_i == item.id,
                      id: "bottom_item_#{item.id}",
                      class: "item-radio",
                      data: { slot: "bottom", image: cl_image_path(item.photo.key) } %>

                  <label for="bottom_item_<%= item.id %>" class="item-card-choice">
                    <% if item.photo.attached? %>
                      <%= cl_image_tag item.photo.key, class: "item-card-image" %>
                    <% end %>

                    <p class="item-card-name"><%= item.name %></p>
                  </label>

                </div>
              <% end %>

            </div>
          </div>
        </div>


        <!-- FOOTWEAR -->
        <div class="offcanvas offcanvas-bottom slot-sheet" tabindex="-1" id="footwear-sheet">
          <div class="offcanvas-header">
            <h5 class="offcanvas-title">Select Shoes</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
          </div>

          <div class="offcanvas-body">
            <div class="items-scroll-row">

              <% @footwear.each do |item| %>
                <div class="item-choice-wrapper">

                  <%= radio_button_tag "outfit[footwear_item_id]",
                      item.id,
                      @outfit.footwear_item_id.to_i == item.id,
                      id: "footwear_item_#{item.id}",
                      class: "item-radio",
                      data: { slot: "footwear", image: cl_image_path(item.photo.key) } %>

                  <label for="footwear_item_<%= item.id %>" class="item-card-choice">
                    <% if item.photo.attached? %>
                      <%= cl_image_tag item.photo.key, class: "item-card-image" %>
                    <% end %>

                    <p class="item-card-name"><%= item.name %></p>
                  </label>

                </div>
              <% end %>

            </div>
          </div>
        </div>


        <!-- OUTER -->
        <div class="offcanvas offcanvas-bottom slot-sheet" tabindex="-1" id="outer-sheet">
          <div class="offcanvas-header">
            <h5 class="offcanvas-title">Select Outer</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
          </div>

          <div class="offcanvas-body">
            <div class="items-scroll-row">

              <% @outers.each do |item| %>
                <div class="item-choice-wrapper">

                  <%= radio_button_tag "outfit[outer_item_id]",
                      item.id,
                      @outfit.outer_item_id.to_i == item.id,
                      id: "outer_item_#{item.id}",
                      class: "item-radio",
                      data: { slot: "outer", image: cl_image_path(item.photo.key) } %>

                  <label for="outer_item_<%= item.id %>" class="item-card-choice">
                    <% if item.photo.attached? %>
                      <%= cl_image_tag item.photo.key, class: "item-card-image" %>
                    <% end %>

                    <p class="item-card-name"><%= item.name %></p>
                  </label>

                </div>
              <% end %>

            </div>
          </div>
        </div>

        <div class="form-actions d-flex justify-content-center mt-4 gap-4">
          <%= f.submit "Create Outfit", class: "main-button" %>
          <% if @outfit.persisted? %>
            <%= link_to "Ask for Advice", chat_outfit_path(@outfit), class: "main-button" %>
          <% end %>
        </div>

      </div>
    </div>

  <% end %>
  <%= render "messages/messages", messages: @messages, outfit: @outfit %>
  <%= render "messages/form", outfit: @outfit, message: @message %>
</div>
