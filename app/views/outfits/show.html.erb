<div class="container pt-3 outfit-show-page">
  <article class="outfit-show-card-minimal">
    <div class="outfit-show-grid">
      <% 4.times do |i| %>
        <% outfit_item = @outfit.outfit_items[i] %>
        <% item = outfit_item&.item %>
        <div class="outfit-show-grid-cell">
          <% if item&.photo&.attached? %>
            <%= cl_image_tag item.photo.key, class: "outfit-show-grid-image" %>
          <% else %>
            <div class="outfit-show-grid-placeholder">No item</div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="outfit-show-content">
      <p class="outfit-show-title"><%= @outfit.name.capitalize.presence || "Untitled Outfit" %></p>

      <% if @outfit.description.present? %>
        <p class="outfit-show-description"><%= @outfit.description %></p>
      <% end %>

      <div class="outfit-show-actions">
        <%= link_to "Edit Outfit", edit_outfit_path(@outfit), class: "main-button" %>
        <%= link_to "All Outfits", outfits_path, class: "main-button outfit-show-secondary-action" %>
      </div>
    </div>
  </article>
</div>
<article class="outfit-show-card-minimal pt-0">
<p class="outfit-show-description mb-3 mx-3">Use Pokeclo AI to see how you would look in this outfit!</p>
<div class="container d-flex px-3 gap-4">
  <%= link_to "Try on!", try_on_outfit_path(@outfit), class: "main-button" %>
  <% if @outfit.photo.attached?  %>
    <button type="button" class="main-button" data-bs-toggle="modal" data-bs-target="#exampleModal">
      Show Me in This Outfit
    </button>
  <% end %>
</div>
</article>
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered"> <div class="modal-content overflow-hidden" style="border-radius: 20px;">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Your image</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body p-0"> <% if @outfit.photo.attached? %>
          <%= cl_image_tag @outfit.photo.key,
                           class: "img-fluid w-100",
                           style: "aspect-ratio: 2 / 3; object-fit: cover; display: block;" %>
        <% end %>
      </div>

      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary w-100 rounded-pill" data-bs-dismiss="modal">Back</button>
      </div>
    </div>
  </div>
</div>

<% if @pending_purchase_items.any? %>
  <div class="offcanvas offcanvas-bottom"
       tabindex="-1"
       id="outfitLeaveOffcanvas"
       data-controller="outfit-purchase-prompt"
       data-outfit-purchase-prompt-items-value="<%= @pending_purchase_items.map { |item| { id: item.id, name: item.name } }.to_json %>"
       aria-labelledby="outfitLeaveOffcanvasLabel"
       style="height: auto; border-top-left-radius: 16px; border-top-right-radius: 16px;">
    <div class="offcanvas-header">
      <h5 class="offcanvas-title" id="outfitLeaveOffcanvasLabel">Bought any of these items?</h5>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
      <p class="mb-2">Before leaving, you can mark purchased items as bought.</p>
      <ul class="outfit-leave-items-grid mb-3">
        <% @pending_purchase_items.each do |item| %>
          <li class="outfit-leave-item-cell">
            <label class="outfit-leave-item-card">
              <input type="checkbox"
                     value="<%= item.id %>"
                     data-outfit-purchase-prompt-target="itemCheckbox"
                     checked>
              <span class="outfit-leave-item-thumb">
                <% if item.photo.attached? %>
                  <%= cl_image_tag item.photo.key, width: 44, height: 44, crop: :fill, class: "outfit-leave-item-image" %>
                <% else %>
                  <span class="outfit-leave-item-placeholder">No image</span>
                <% end %>
              </span>
              <span class="outfit-leave-item-name"><%= item.name %></span>
            </label>
          </li>
        <% end %>
      </ul>
      <div class="d-flex gap-2">
        <button type="button" id="leave-mark-bought" data-action="outfit-purchase-prompt#leaveAndMarkBought" class="main-button">Mark selected as bought</button>
        <button type="button" id="leave-without-marking" data-action="outfit-purchase-prompt#leaveWithoutMarking" class="main-button outfit-show-secondary-action">No, leave anyway</button>
      </div>
    </div>
  </div>
<% end %>
