<div class="container py-3 pb-5 outfit-show-page">
  <article class="outfit-show-card-minimal">
    <div class="outfit-show-grid">
      <% 4.times do |i| %>
        <% outfit_item = @outfit.outfit_items[i] %>
        <% item = outfit_item&.item %>
        <div class="outfit-show-grid-cell">
          <% if item&.photo&.attached? %>
            <%= cl_image_tag item.photo.key, class: "outfit-show-grid-image" %>
          <% else %>
            <div class="outfit-show-grid-placeholder">No item</div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="outfit-show-content">
      <p class="outfit-show-title"><%= @outfit.name.capitalize.presence || "Untitled Outfit" %></p>

      <% if @outfit.description.present? %>
        <p class="outfit-show-description"><%= @outfit.description %></p>
      <% end %>

      <div class="outfit-show-actions">
        <%= link_to "Edit Outfit", edit_outfit_path(@outfit), class: "main-button" %>
        <%= link_to "All Outfits", outfits_path, class: "main-button outfit-show-secondary-action" %>
      </div>
    </div>
  </article>
</div>
