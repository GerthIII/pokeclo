<nav class="navbar navbar-expand-sm navbar-light navbar-lewagon">
  <div class="container-fluid d-flex justify-content-between align-items-center px-4">

    <%= link_to dashboard_path, class: "navbar-brand #{'active' if current_page?(dashboard_path)}" do %>
      <i class="fa-solid fa-house"></i>
    <% end %>

    <%= link_to items_path, class: "navbar-brand #{'active' if controller_name == 'items'}" do %>
      <i class="fa-solid fa-shirt"></i>
    <% end %>

    <%= form_with(model: Item, url:capture_photo_items_path, local: true, class: "d-inline", method: :post) do |f| %>
      <label class="mb-0" style="cursor: pointer;">
        <i class="fa-solid fa-camera fs-2"></i>
        <%= f.file_field :photo,
          accept: "image/*",
          capture: "camera",
          class: "d-none",
          onchange: "this.form.submit();" %>
      </label>
    <% end %>

    <%= link_to outfits_path, class: "navbar-brand #{'active' if controller_name == 'outfits'}" do %>
      <i class="fa-solid fa-star"></i>
    <% end %>

    <button class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarSupportedContent"
            aria-controls="navbarSupportedContent"
            aria-expanded="false"
            aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto">
        <% if user_signed_in? %>
          <li class="nav-item active">
            <%= link_to "Dashboard", dashboard_path, class: "nav-link" %>
          </li>
          <li class="nav-item active">
            <%= link_to "Log out", destroy_user_session_path,
              data: { turbo_method: :delete },
              class: "nav-link" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Login", new_user_session_path, class: "nav-link" %>
            <%= link_to "Sign In", new_user_registration_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>

  </div>
</nav>
